{
    "swagger": "2.0",
    "info": {
        "description": "REST API for Quran data, prayer times, and search functionality",
        "title": "Quran API",
        "termsOfService": "http://swagger.io/terms/",
        "contact": {
            "name": "API Support",
            "url": "https://github.com/anugrahsputra/go-quran-api",
            "email": "support@example.com"
        },
        "license": {
            "name": "Apache 2.0",
            "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
        },
        "version": "1.0"
    },
    "host": "localhost:8081",
    "basePath": "/",
    "paths": {
        "/api/v1/ayah/{ayah_id}": {
            "get": {
                "description": "Retrieve detailed information about a specific Ayah including tafsir",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Ayah"
                ],
                "summary": "Get Ayah Detail",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Ayah ID",
                        "name": "ayah_id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/dto.DetailAyahResp"
                        }
                    }
                }
            }
        },
        "/api/v1/prayer-time": {
            "get": {
                "description": "Retrieve prayer times for a specific city and timezone",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Prayer Time"
                ],
                "summary": "Get Prayer Times",
                "parameters": [
                    {
                        "type": "string",
                        "description": "City/Address",
                        "name": "address",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Timezone (e.g., Asia/Jakarta)",
                        "name": "timezonestring",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/dto.PrayerTimeResp"
                        }
                    }
                }
            }
        },
        "/api/v1/search": {
            "get": {
                "description": "Search for Quran verses using full-text search",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Search"
                ],
                "summary": "Search Quran",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Search query",
                        "name": "q",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Page number (default: 1)",
                        "name": "page",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Items per page (default: 10)",
                        "name": "limit",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/dto.SearchResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/surah": {
            "get": {
                "description": "Retrieve a list of all Surah in the Quran",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Surah"
                ],
                "summary": "Get List of Surah",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/dto.SurahListResp"
                        }
                    }
                }
            }
        },
        "/api/v1/surah/{surah_id}": {
            "get": {
                "description": "Retrieve detailed information about a specific Surah with pagination for verses",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Surah"
                ],
                "summary": "Get Surah Detail",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Surah ID",
                        "name": "surah_id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Page number (default: 1)",
                        "name": "page",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Items per page (default: 10, max: 100)",
                        "name": "limit",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/dto.SurahDetailResp"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "dto.Date": {
